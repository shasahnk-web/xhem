{
  "version": 2,
  "builds": [
    {
      "src": "server.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",   "dest": "server.py" },
    { "src": "/proxy/(.*)", "dest": "server.py" },
    { "src": "/(.*)",       "dest": "/public/$1" }
  ]
}
